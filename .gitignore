# Ignore all files (binaries)
*
# Except for directories
!*/
# Except for files with extensions (source)
!*.*

# Specifically whitelist common extensionless files
!Makefile
!LICENSE
!Dockerfile

# Specifically ignore generated Go files (they have extensions)
*_imgo_gen.go

# Go standard ignores (build artifacts)
bin/
obj/
vendor/
.deps/

# Test coverage
*.out
*.prof

# OS & IDE
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# Project specific
check.go
