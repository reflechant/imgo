package main

import "fmt"

func main() {
	// make(map)
	m := make(map[string]int)
	fmt.Printf("make(map) len: %d\n", len(m))

	m2 := make(map[string]int, 100) // with hint
	fmt.Printf("make(map, 100) len: %d\n", len(m2))

	// make(list)
	l := make([]int, 0)
	fmt.Printf("make([]int, 0) len: %d\n", len(l))

	l2 := make([]int, 10) // deviation! should be empty
	fmt.Printf("make([]int, 10) len: %d\n", len(l2))
}

// -- EXPECT --
// make(map) len: 0
// make(map, 100) len: 0
// make([]int, 0) len: 0
// make([]int, 10) len: 0
