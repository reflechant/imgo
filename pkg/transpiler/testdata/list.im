package main

import "fmt"

func main() {
	// List literal
	l := []int{10, 20}
	fmt.Printf("Initial len: %d\n", len(l))

	// Append
	l1 := l.Append(30)
	fmt.Printf("After append: l len=%d, l1 len=%d\n", len(l), len(l1))

	// Indexing
	fmt.Printf("Index 0: %d\n", l1[0])
	fmt.Printf("Index 2: %d\n", l1[2])

	// Range
	fmt.Print("Range: ")
	for i, v := range l1 {
		fmt.Printf("[%d]:%d ", i, v)
	}
	fmt.Println()
}

// -- EXPECT --
// Initial len: 2
// After append: l len=2, l1 len=3
// Index 0: 10
// Index 2: 30
// Range: [0]:10 [1]:20 [2]:30 
