package main

import "fmt"

func main() {
	l := []int{10, 20, 30, 40, 50}

	a := l[1:4]
	fmt.Printf("a: len=%d first=%d last=%d\n", len(a), a[0], a[len(a)-1])

	b := l[:3]
	fmt.Printf("b: len=%d first=%d last=%d\n", len(b), b[0], b[len(b)-1])

	c := l[2:]
	fmt.Printf("c: len=%d first=%d last=%d\n", len(c), c[0], c[len(c)-1])

	d := l[:]
	fmt.Printf("d: len=%d first=%d last=%d\n", len(d), d[0], d[len(d)-1])

	empty := l[2:2]
	fmt.Printf("empty: len=%d\n", len(empty))
}

// -- EXPECT --
// a: len=3 first=20 last=40
// b: len=3 first=10 last=30
// c: len=3 first=30 last=50
// d: len=5 first=10 last=50
// empty: len=0
