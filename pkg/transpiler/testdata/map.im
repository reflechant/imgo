package main

import "fmt"

func main() {
	// Map literal
	m := map[string]int{"a": 1, "b": 2}
	fmt.Printf("Initial len: %d\n", len(m))

	// Set returns new map
	m1 := m.Set("c", 3)
	fmt.Printf("After set 'c': m len=%d, m1 len=%d\n", len(m), len(m1))

	// Get (1-value)
	fmt.Printf("Get 'a': %d\n", m1["a"])
	fmt.Printf("Get 'nonexistent': %d\n", m1["x"])

	// Lookup (2-value)
	val, ok := m1["b"]
	fmt.Printf("Lookup 'b': val=%d, ok=%v\n", val, ok)
	val2, ok2 := m1["x"]
	fmt.Printf("Lookup 'x': val=%d, ok=%v\n", val2, ok2)

	// Delete
	m2 := m1.Delete("a")
	fmt.Printf("After delete 'a': m1 len=%d, m2 len=%d\n", len(m1), len(m2))

	// Range (desugared to All)
	fmt.Print("Range: ")
	for k, v := range m {
		fmt.Printf("%s:%d ", k, v)
	}
	fmt.Println()
}

// -- EXPECT --
// Initial len: 2
// After set 'c': m len=2, m1 len=3
// Get 'a': 1
// Get 'nonexistent': 0
// Lookup 'b': val=2, ok=true
// Lookup 'x': val=0, ok=false
// After delete 'a': m1 len=3, m2 len=2
// Range: a:1 b:2 
